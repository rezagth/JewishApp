# Environment Variables Template
# Copier ce fichier en .env et remplir avec vos valeurs

# === FIREBASE ===
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
FIREBASE_APP_ID=your_app_id_here

# === EXTERNAL APIs ===
# Sefaria (Textes liturgiques - Libre, pas de clé requise)
SEFARIA_API_URL=https://www.sefaria.org/api/

# Hebcal (Calendrier hébraïque - Libre)
HEBCAL_API_URL=https://www.hebcal.com/api/

# Google Maps (Géocodage - Optionnel)
GOOGLE_MAPS_API_KEY=optional_google_maps_key

# === APPLICATION ===
# Environment: development | staging | production
ENV=development

# Log level: debug | info | warn | error
LOG_LEVEL=debug

# Feature flags
ENABLE_COMMUNITY=true
ENABLE_NOTIFICATIONS=true
ENABLE_OFFLINE_MODE=false

# === EXPO / EAS ===
# Obtenir depuis Expo.dev après création du projet
EXPO_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# === DEPLOYMENT ===
# Pour EAS submit
APPLE_ID=your_apple_id@example.com
APPLE_PASSWORD=your_app_specific_password
GOOGLE_PLAY_JSON_KEY_PATH=./google-play-key.json
